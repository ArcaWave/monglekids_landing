# Supabase project for the landing waitlist.
# Dashboard → Project Settings → API
#  - URL:      "Project URL"
#  - anon key: "Project API keys" → anon public
# The anon key is safe to expose in the client; the waitlist table is
# protected with an INSERT-only RLS policy (see supabase/waitlist.sql).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY
