# ============================================================
# Client-side (VITE_ prefix → bundled into the browser build)
# ============================================================

# Supabase project for the landing waitlist.
# Dashboard → Project Settings → API
#  - URL:      "Project URL"
#  - anon key: "Project API keys" → anon public
# The anon key is safe to expose in the client; the waitlist table is
# protected with an INSERT-only RLS policy (see supabase/waitlist.sql).
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=YOUR-ANON-PUBLIC-KEY

# ============================================================
# Server-only (NO VITE_ prefix — never reaches the client bundle).
# Set these in Vercel → Project → Settings → Environment Variables.
# Used by the serverless functions in /api and scripts/send-newsletter.mjs.
# ============================================================

# Same Supabase project URL as above (repeated without the VITE_ prefix
# because serverless functions don't read import.meta.env).
SUPABASE_URL=https://YOUR-PROJECT.supabase.co

# ⚠️ SECRET. Bypasses RLS entirely. Server-side only, never commit.
# Put the real value in `.env` (gitignored) — NEVER in this file.
# Dashboard → Project Settings → API → "service_role" key.
SUPABASE_SERVICE_ROLE_KEY=YOUR-SERVICE-ROLE-KEY

# Resend (https://resend.com) — newsletter + welcome emails.
# ⚠️ SECRET. Real value goes in `.env` (gitignored), not here.
RESEND_API_KEY=re_YOUR-KEY

# Sender address. The domain must be verified in Resend first
# (Resend → Domains → add monglekids.com → add the DNS records in
# Vercel DNS). Until then the resend.dev fallback only delivers to
# your own account email.
RESEND_FROM="MongleKids <news@monglekids.com>"

# ⚠️ SECRET. Gates the read-only admin export at GET /api/subscribers
# (used by the Google Sheets sync in scripts/sheets-sync.gs). Pick a
# long random value — generate one with:  openssl rand -hex 32
# Put the SAME value in Vercel env AND in the Sheet's Script Properties
# (API_TOKEN). Real value goes in `.env` (gitignored), not here.
ADMIN_TOKEN=YOUR-LONG-RANDOM-ADMIN-TOKEN
